{
  "name": "presentation-testing-smarter-ai-playwright",
  "version": "2.0.0",
  "description": "Testing smarter: Bringing AI into your E2E testing workflows — Techorama 2026 / ECS 2026",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:broken": "playwright test tests/approval/broken-for-healer.spec.ts",
    "test:auth": "playwright test tests/auth/auth.setup.ts",
    "test:report": "playwright show-report",
    "serve": "npx serve apps/approval-portal -l 3000",
    "analyze": "node scripts/analyze-failures.js",
    "agents:init": "npx playwright init-agents --loop=vscode",
    "agents:init:claude": "npx playwright init-agents --loop=claude"
  },
  "keywords": ["playwright", "testing", "ai", "mcp", "e2e"],
  "author": "Elio Struyf",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0",
    "serve": "^14.2.0"
  }
}
